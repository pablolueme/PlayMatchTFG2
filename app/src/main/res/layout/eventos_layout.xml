<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_eventos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <include
        android:id="@+id/include_bottom_nav_eventos"
        layout="@layout/bottom_nav_visual_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_eventos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="@dimen/spacing_20"
        android:paddingTop="@dimen/spacing_20"
        android:paddingEnd="@dimen/spacing_20"
        android:paddingBottom="@dimen/spacing_20"
        app:layout_constraintBottom_toTopOf="@id/include_bottom_nav_eventos"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/container_eventos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_titulo_eventos"
                style="@style/Text.PlayMatch.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/eventos_titulo" />

            <TextView
                android:id="@+id/txt_subtitulo_eventos"
                style="@style/Text.PlayMatch.ScreenSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_4"
                android:text="@string/eventos_subtitulo" />

            <Button
                android:id="@+id/btn_crear_evento_eventos"
                style="@style/Widget.PlayMatch.ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="@string/action_crear_evento"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progress_eventos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_20"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txt_estado_lista_eventos"
                style="@style/Text.PlayMatch.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="@string/msg_eventos_cargando"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/container_lista_eventos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
