<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_login"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_login"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/spacing_24"
        android:paddingTop="@dimen/spacing_32"
        android:paddingEnd="@dimen/spacing_24"
        android:paddingBottom="@dimen/spacing_32"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/container_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- Header -->
            <ImageView
                android:id="@+id/img_logo_login"
                android:layout_width="@dimen/icon_size_56"
                android:layout_height="@dimen/icon_size_56"
                android:background="@drawable/bg_avatar_circular"
                android:contentDescription="@string/cd_logo_playmatch"
                android:padding="@dimen/spacing_12"
                android:src="@mipmap/ic_launcher"
                app:tint="@color/primary_brand" />

            <TextView
                android:id="@+id/txt_logo_login"
                style="@style/Text.PlayMatch.Logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                android:text="@string/app_brand_name" />

            <TextView
                android:id="@+id/txt_titulo_login"
                style="@style/Text.PlayMatch.ScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                android:gravity="center"
                android:text="@string/login_titulo" />

            <TextView
                android:id="@+id/txt_subtitulo_login"
                style="@style/Text.PlayMatch.ScreenSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:gravity="center"
                android:text="@string/login_subtitulo" />

            <!-- Formulario -->
            <EditText
                android:id="@+id/edt_correo_login"
                style="@style/Widget.PlayMatch.Input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_28"
                android:hint="@string/hint_correo"
                android:importantForAutofill="yes"
                android:inputType="textEmailAddress" />

            <EditText
                android:id="@+id/edt_password_login"
                style="@style/Widget.PlayMatch.Input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_12"
                android:hint="@string/hint_contrasena"
                android:importantForAutofill="yes"
                android:inputType="textPassword" />

            <CheckBox
                android:id="@+id/chk_recordar_sesion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:buttonTint="@color/primary_brand"
                android:text="@string/login_recordar_sesion"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_14" />

            <!-- Boton principal -->
            <Button
                android:id="@+id/btn_iniciar_sesion"
                style="@style/Widget.PlayMatch.ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="@string/action_iniciar_sesion" />

            <ProgressBar
                android:id="@+id/progress_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txt_ir_recuperar_contrasena"
                style="@style/Widget.PlayMatch.Link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="@string/login_olvide_contrasena" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    style="@style/Text.PlayMatch.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_no_tienes_cuenta" />

                <TextView
                    android:id="@+id/txt_ir_registro"
                    style="@style/Widget.PlayMatch.Link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_6"
                    android:text="@string/action_registrate" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
