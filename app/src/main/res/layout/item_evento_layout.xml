<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_item_evento"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_16"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="@dimen/radius_24"
    app:cardElevation="@dimen/elevation_card"
    app:strokeColor="@color/border_light"
    app:strokeWidth="@dimen/stroke_1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Imagen superior -->
        <ImageView
            android:id="@+id/img_item_evento"
            android:layout_width="match_parent"
            android:layout_height="@dimen/list_image_height"
            android:background="@drawable/bg_placeholder_imagen"
            android:contentDescription="@string/cd_imagen_evento"
            android:padding="@dimen/spacing_24"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="@color/primary_brand_dark" />

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <TextView
                android:id="@+id/txt_titulo_item_evento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sample_evento_titulo"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_10"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_16"
                    android:layout_height="@dimen/icon_size_16"
                    android:contentDescription="@string/cd_icono_ajustes"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="@color/text_tertiary" />

                <TextView
                    style="@style/Text.PlayMatch.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_8"
                    android:text="@string/sample_evento_ubicacion" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_6"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_16"
                    android:layout_height="@dimen/icon_size_16"
                    android:contentDescription="@string/cd_icono_eventos"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="@color/text_tertiary" />

                <TextView
                    style="@style/Text.PlayMatch.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_8"
                    android:text="@string/sample_evento_fecha" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_ver_detalle_item_evento"
                style="@style/Widget.PlayMatch.ButtonSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="@string/action_ver_detalle" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
