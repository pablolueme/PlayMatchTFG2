<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_historial_partidos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <ImageButton
        android:id="@+id/btn_volver_historial_partidos"
        android:layout_width="@dimen/icon_size_40"
        android:layout_height="@dimen/icon_size_40"
        android:layout_marginStart="@dimen/spacing_20"
        android:layout_marginTop="@dimen/spacing_16"
        android:background="@drawable/bg_icono_circulo_claro"
        android:contentDescription="@string/action_volver"
        android:padding="@dimen/spacing_10"
        android:src="@android:drawable/ic_media_previous"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/primary_brand_dark" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_historial_partidos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="@dimen/spacing_20"
        android:paddingTop="@dimen/spacing_12"
        android:paddingEnd="@dimen/spacing_20"
        android:paddingBottom="@dimen/spacing_20"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_volver_historial_partidos">

        <LinearLayout
            android:id="@+id/container_historial_partidos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_titulo_historial"
                style="@style/Text.PlayMatch.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/historial_titulo" />

            <TextView
                android:id="@+id/txt_subtitulo_historial"
                style="@style/Text.PlayMatch.ScreenSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_4"
                android:text="@string/historial_subtitulo" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_filtro_todos_historial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_padel"
                        android:paddingStart="@dimen/spacing_14"
                        android:paddingTop="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_14"
                        android:paddingBottom="@dimen/spacing_8"
                        android:text="@string/historial_filtro_todos"
                        android:textColor="@color/chip_padel_text"
                        android:textSize="@dimen/text_size_12"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chip_filtro_pendientes_historial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:background="@drawable/bg_chip_pendiente"
                        android:paddingStart="@dimen/spacing_14"
                        android:paddingTop="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_14"
                        android:paddingBottom="@dimen/spacing_8"
                        android:text="@string/historial_filtro_pendientes"
                        android:textColor="@color/warning_text"
                        android:textSize="@dimen/text_size_12"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chip_filtro_finalizados_historial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:background="@drawable/bg_chip_exito"
                        android:paddingStart="@dimen/spacing_14"
                        android:paddingTop="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_14"
                        android:paddingBottom="@dimen/spacing_8"
                        android:text="@string/historial_filtro_finalizados"
                        android:textColor="@color/success_text"
                        android:textSize="@dimen/text_size_12"
                        android:textStyle="bold" />

                </LinearLayout>
            </HorizontalScrollView>

            <ProgressBar
                android:id="@+id/progress_historial_partidos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_24"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txt_estado_lista_historial"
                style="@style/Text.PlayMatch.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="@string/msg_historial_cargando"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/container_lista_historial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
