<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_recuperar_contrasena"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_recuperar_contrasena"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="@dimen/spacing_24"
        android:paddingTop="@dimen/spacing_32"
        android:paddingEnd="@dimen/spacing_24"
        android:paddingBottom="@dimen/spacing_32"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/container_recuperar_contrasena"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- Icono superior -->
            <ImageView
                android:id="@+id/img_icono_recuperar"
                android:layout_width="@dimen/icon_size_56"
                android:layout_height="@dimen/icon_size_56"
                android:background="@drawable/bg_icono_circulo_claro"
                android:contentDescription="@string/cd_icono_ajustes"
                android:padding="@dimen/spacing_14"
                android:src="@android:drawable/ic_lock_idle_lock"
                android:tint="@color/primary_brand" />

            <TextView
                android:id="@+id/txt_titulo_recuperar"
                style="@style/Text.PlayMatch.ScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                android:gravity="center"
                android:text="@string/recuperar_titulo" />

            <TextView
                android:id="@+id/txt_subtitulo_recuperar"
                style="@style/Text.PlayMatch.ScreenSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:gravity="center"
                android:text="@string/recuperar_subtitulo" />

            <EditText
                android:id="@+id/edt_correo_recuperar"
                style="@style/Widget.PlayMatch.Input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_24"
                android:hint="@string/hint_correo"
                android:inputType="textEmailAddress" />

            <Button
                android:id="@+id/btn_enviar_enlace"
                style="@style/Widget.PlayMatch.ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="@string/action_enviar_enlace" />

            <TextView
                android:id="@+id/txt_volver_login"
                style="@style/Widget.PlayMatch.Link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="@string/action_volver_login" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
