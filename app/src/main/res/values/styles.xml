<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Text" />
    <style name="Widget" />
    <style name="Text.PlayMatch" />
    <style name="Widget.PlayMatch" />

    <style name="Text.PlayMatch.Logo">
        <item name="android:textColor">@color/primary_brand</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_24</item>
    </style>

    <style name="Text.PlayMatch.ScreenTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_30</item>
    </style>

    <style name="Text.PlayMatch.ScreenSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_14</item>
    </style>

    <style name="Text.PlayMatch.SectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_20</item>
    </style>

    <style name="Text.PlayMatch.Body">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_14</item>
    </style>

    <style name="Text.PlayMatch.Caption">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">@dimen/text_size_12</item>
    </style>

    <style name="Text.PlayMatch.NavLabel">
        <item name="android:textColor">@color/nav_icon_inactive</item>
        <item name="android:textSize">@dimen/text_size_12</item>
    </style>

    <style name="Widget.PlayMatch.Input">
        <item name="android:background">@drawable/bg_input_redondeado</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:paddingStart">@dimen/spacing_16</item>
        <item name="android:paddingEnd">@dimen/spacing_16</item>
        <item name="android:paddingTop">@dimen/spacing_14</item>
        <item name="android:paddingBottom">@dimen/spacing_14</item>
        <item name="android:textSize">@dimen/text_size_14</item>
    </style>

    <style name="Widget.PlayMatch.ScoreInput" parent="Widget.PlayMatch.Input">
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/text_size_18</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.PlayMatch.ButtonPrimary">
        <item name="android:background">@drawable/bg_boton_primario</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:paddingStart">@dimen/spacing_20</item>
        <item name="android:paddingEnd">@dimen/spacing_20</item>
        <item name="android:textSize">@dimen/text_size_16</item>
    </style>

    <style name="Widget.PlayMatch.ButtonSecondary">
        <item name="android:background">@drawable/bg_boton_secundario</item>
        <item name="android:textColor">@color/primary_brand</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:paddingStart">@dimen/spacing_20</item>
        <item name="android:paddingEnd">@dimen/spacing_20</item>
        <item name="android:textSize">@dimen/text_size_16</item>
    </style>

    <style name="Widget.PlayMatch.ButtonLight">
        <item name="android:background">@drawable/bg_boton_claro</item>
        <item name="android:textColor">@color/primary_brand</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:paddingStart">@dimen/spacing_20</item>
        <item name="android:paddingEnd">@dimen/spacing_20</item>
        <item name="android:textSize">@dimen/text_size_16</item>
    </style>

    <style name="Widget.PlayMatch.ButtonDanger">
        <item name="android:background">@drawable/bg_boton_peligro</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:paddingStart">@dimen/spacing_20</item>
        <item name="android:paddingEnd">@dimen/spacing_20</item>
        <item name="android:textSize">@dimen/text_size_16</item>
    </style>

    <style name="Widget.PlayMatch.Link">
        <item name="android:textColor">@color/primary_brand</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_14</item>
    </style>

</resources>
