<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_crear_evento"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_crear_evento"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="@dimen/spacing_24"
        android:paddingTop="@dimen/spacing_24"
        android:paddingEnd="@dimen/spacing_24"
        android:paddingBottom="@dimen/spacing_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/container_crear_evento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_titulo_crear_evento"
                style="@style/Text.PlayMatch.ScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/crear_evento_titulo" />

            <TextView
                android:id="@+id/txt_subtitulo_crear_evento"
                style="@style/Text.PlayMatch.ScreenSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:text="@string/crear_evento_subtitulo" />

            <EditText
                android:id="@+id/edt_titulo_crear_evento"
                style="@style/Widget.PlayMatch.Input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_20"
                android:hint="@string/hint_titulo_evento"
                android:inputType="textCapSentences" />

            <EditText
                android:id="@+id/edt_descripcion_crear_evento"
                style="@style/Widget.PlayMatch.Input"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="@dimen/spacing_12"
                android:gravity="top|start"
                android:hint="@string/hint_descripcion_evento"
                android:inputType="textMultiLine"
                android:minLines="4" />

            <EditText
                android:id="@+id/edt_fecha_crear_evento"
                style="@style/Widget.PlayMatch.Input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_12"
                android:hint="@string/hint_fecha"
                android:inputType="date" />

            <EditText
                android:id="@+id/edt_hora_crear_evento"
                style="@style/Widget.PlayMatch.Input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_12"
                android:hint="@string/hint_hora"
                android:inputType="time" />

            <EditText
                android:id="@+id/edt_ubicacion_crear_evento"
                style="@style/Widget.PlayMatch.Input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_12"
                android:hint="@string/hint_ubicacion"
                android:inputType="textPostalAddress" />

            <Button
                android:id="@+id/btn_publicar_evento"
                style="@style/Widget.PlayMatch.ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_20"
                android:text="@string/action_publicar_evento" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
